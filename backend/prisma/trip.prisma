model Trip {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  startedAt DateTime @db.Date
  endedAt   DateTime? @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  members   TripMember[]
  pathPoints PathPoint[]
  destinations Destination[]
}