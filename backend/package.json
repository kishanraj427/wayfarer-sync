{
  "name": "backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "bunx prisma generate && bunx prisma db push",
    "start": "docker-compose up -d",
    "reset": "docker-compose down",
    "dev": "bun --watch src/index.ts",
    "pg-port": "sudo ss -lptn 'sport = :5432'",
    "build": "bun build src/index.ts --outdir ./dist --target node",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "axios": "1.14.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "rate-limit-redis": "^4.3.1",
    "zod": "^4.3.6"
  }
}